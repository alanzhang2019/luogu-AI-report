{"time": 952, "memory": 684, "problem": {"pid": "P6267", "title": "[SHOI2002] N的连续数拆分", "difficulty": 3, "type": "P"}, "sourceCodeLength": 221, "submitTime": 1740133030, "language": 27, "user": {"uid": 1353311, "name": "AC_Coder4869", "avatar": "https://cdn.luogu.com.cn/upload/usericon/1353311.png", "slogan": "願", "isAdmin": false, "isBanned": false, "color": "Green", "ccfLevel": 6, "xcpcLevel": 0, "background": ""}, "id": 203953640, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\nusing namespace std;\ntypedef long long LL;\n\nint main()\n{\n\tLL n, ans = 0;\n\tcin >> n;\n\tn *= 2;\n\tfor(LL i = 1; i * i <= n; i++)\n\t{\n\t\tif(n % i == 0 && (i + n / i) % 2 != 0)\n\t\t\tans++;\n\t}\n\tcout << ans;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 15:34:18"}