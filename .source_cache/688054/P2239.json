{"time": 34, "memory": 612, "problem": {"pid": "P2239", "title": "[NOIP 2014 普及组] 螺旋矩阵", "difficulty": 3, "type": "P"}, "sourceCodeLength": 302, "submitTime": 1729325988, "language": 28, "user": {"uid": 688054, "name": "markwang0529", "avatar": "https://cdn.luogu.com.cn/upload/usericon/688054.png", "slogan": "无限进步", "isAdmin": false, "isBanned": false, "color": "Orange", "ccfLevel": 5, "xcpcLevel": 0, "background": ""}, "id": 183252747, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\nusing namespace std;\nint dfs(int n,int i,int j)\n{\n    if(i==1) return j;\n    if(j==n) return n+i-1;\n    if(i==n) return 3*n-1-j;\n    if(j==1) return 4*n-2-i;\n    return dfs(n-2,i-1,j-1)+4*n-4;\n}\nint main()\n{\n    int n,i,j;\n    cin>>n>>i>>j;\n    cout<<dfs(n,i,j);\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 17:23:41"}