{"time": 65, "memory": 12668, "problem": {"pid": "P2585", "title": "[ZJOI2006] 三色二叉树", "difficulty": 4, "type": "P"}, "sourceCodeLength": 1039, "submitTime": 1736835238, "language": 28, "user": {"uid": 907368, "name": "andycode", "avatar": "https://cdn.luogu.com.cn/upload/usericon/907368.png", "slogan": "Always continue, never break || 天灵灵，地灵灵，代码一定行 || 逸一时，误一世，逸久逸久罢以零 || 服役 OIer", "isAdmin": false, "isBanned": false, "color": "Orange", "ccfLevel": 7, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/sob0rftg.png"}, "id": 198163790, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include <bits/stdc++.h>\r\nusing namespace std;\r\nconst int N=5e5+5;\r\nint n,l[N],r[N],f[N][2][2];\r\nchar s[N];\r\nint build(int x){\r\n\tif(s[x-1]=='0')\r\n\t\treturn x;\r\n\telse if(s[x-1]=='1'){\r\n\t\tl[x]=x+1;\r\n\t\treturn build(x+1);\r\n\t}else{\r\n\t\tl[x]=x+1;\r\n\t\tr[x]=build(x+1)+1;\r\n\t\treturn build(r[x]);\r\n\t}\r\n}\r\nvoid dfs(int x){\r\n\tf[x][1][0]=f[x][1][1]=1<<30;\r\n\tif(!l[x] && !r[x])\r\n\t\tf[x][0][0]=f[x][1][0]=0,f[x][0][1]=f[x][1][1]=1;\r\n\telse if(l[x] && !r[x]){\r\n\t\tdfs(l[x]);\r\n\t\tf[x][0][0]=max(f[l[x]][0][0],f[l[x]][0][1]),f[x][0][1]=1+f[l[x]][0][0];\r\n\t\tf[x][1][0]=min(f[l[x]][1][0],f[l[x]][1][1]),f[x][1][1]=1+f[l[x]][1][0];\r\n\t}else{\r\n\t\tdfs(l[x]),dfs(r[x]);\r\n\t\tf[x][0][0]=max(f[l[x]][0][1]+f[r[x]][0][0],f[l[x]][0][0]+f[r[x]][0][1]);\r\n\t\tf[x][0][1]=1+f[l[x]][0][0]+f[r[x]][0][0];\r\n\t\tf[x][1][0]=min(f[l[x]][1][1]+f[r[x]][1][0],f[l[x]][1][0]+f[r[x]][1][1]);\r\n\t\tf[x][1][1]=1+f[l[x]][1][0]+f[r[x]][1][0];\r\n\t}\r\n}\r\nint main(){\r\n\tscanf(\"%s\",s);\r\n\tn=strlen(s);\r\n\tbuild(1);\r\n\tdfs(1);\r\n\tprintf(\"%d %d\",max(f[1][0][0],f[1][0][1]),min(f[1][1][0],f[1][1][1]));\r\n\treturn 0;\r\n}", "_detail_requested": true, "_cached_at": "2026-06-05 20:26:10"}