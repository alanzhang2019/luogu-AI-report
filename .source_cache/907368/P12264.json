0],f[i&1][j][k][1][1]*p);\n                add(f[i&1^1][j][k+1][1][0],f[i&1][j][k][1][2]*p);\n                // AR\n                if(j)\n                    add(f[i&1^1][j-1][k][0][0],f[i&1][j][k][0][0]*q),\n                    add(f[i&1^1][j-1][k][1][0],f[i&1][j][k][1][0]*q),\n                    add(f[i&1^1][j-1][k][1][1],f[i&1][j][k][1][1]*q),\n                    add(f[i&1^1][j-1][k][1][2],f[i&1][j][k][1][2]*q);\n                else{\n                    add(f[i&1^1][0][k][1][0],f[i&1][0][k][1][2]*q);\n                    if(k>=2)\n                        add(f[i&1^1][0][k-2][0][0],f[i&1][0][k][0][0]*q),\n                        add(f[i&1^1][0][k-2][1][0],f[i&1][0][k][1][0]*q),\n                        add(f[i&1^1][0][k-2][1][1],f[i&1][0][k][1][1]*q);\n                }\n                //B\n                add(f[i&1^1][j][k+1][0][0],f[i&1][j][k][0][0]*r);\n                add(f[i&1^1][j][k+1][1][0],f[i&1][j][k][1][0]*r);\n                add(f[i&1^1][j][k+1][1][1],f[i&1][j][k][1][1]*r);\n                add(f[i&1^1][j][k+1][1][2],f[i&1][j][k][1][2]*r);\n                //C\n            }\n    \tprintf(\"%d \",(f[i&1^1][0][0][0][0]+f[i&1^1][0][0][1][0])%mod);\n    }\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 19:39:48"}