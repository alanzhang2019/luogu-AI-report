e'){\n        int cnt=0;\n        memset(ph,0,sizeof(ph));\n        memset(pl,0,sizeof(pl));\n        memset(pg,0,sizeof(pg));\n        for(int i=0;i<9;i++)\n            for(int j=0;j<9;j++){\n                if(s[i*9+j]=='.')\n                    cnt++,a[i][j]=0;\n                else{\n                    a[i][j]=s[i*9+j]-'0';\n                    ph[i]|=(1<<a[i][j]-1);\n                    pl[j]|=(1<<a[i][j]-1);\n                    pg[g[i][j]]|=(1<<a[i][j]-1);\n                }\n            }\n        dfs(cnt);\n    }\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 20:19:16"}