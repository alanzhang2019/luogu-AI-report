{"time": 163, "memory": 824, "problem": {"pid": "P10500", "title": "Rainbow 的信号", "difficulty": 4, "type": "P"}, "sourceCodeLength": 1241, "submitTime": 1749708345, "language": 28, "user": {"uid": 907368, "name": "andycode", "avatar": "https://cdn.luogu.com.cn/upload/usericon/907368.png", "slogan": "Always continue, never break || 天灵灵，地灵灵，代码一定行 || 逸一时，误一世，逸久逸久罢以零 || 服役 OIer", "isAdmin": false, "isBanned": false, "color": "Orange", "ccfLevel": 7, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/sob0rftg.png"}, "id": 220219033, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include <bits/stdc++.h>\nusing namespace std;\n\nconst int N=1e5+5;\n\nint n,a[N];\nlong long f[2][30][3][2];\n//f[i][j][k][b(0/1)]表示第i项结尾，第k种运算方式下，结尾在二进制下第j位的值为x的方案数\n\nint main(){\n    scanf(\"%d\",&n);\n    for(int i=1;i<=n;i++)\n        scanf(\"%d\",&a[i]);\n    double ans1=0,ans2=0,ans3=0;\n    for(int i=1;i<=n;i++){\n        memset(f[i&1],0,sizeof(f[i&1]));\n        for(int j=0;j<30;j++){\n            int num=(bool)(a[i]&(1<<j));\n            f[i&1][j][0][0]=f[(i&1)^1][j][0][num]+(!num)*2;\n            f[i&1][j][0][1]=f[(i&1)^1][j][0][num^1]+num*2;\n            if(num){\n                f[i&1][j][1][1]=f[(i&1)^1][j][1][1]+2;\n                f[i&1][j][1][0]=f[(i&1)^1][j][1][0];\n                f[i&1][j][2][1]=f[(i&1)^1][j][2][0]+f[(i&1)^1][j][2][1]+2;\n            }else{\n                f[i&1][j][1][0]=f[(i&1)^1][j][1][0]+f[(i&1)^1][j][1][1]+2;\n                f[i&1][j][2][0]=f[(i&1)^1][j][2][0]+2;\n                f[i&1][j][2][1]=f[(i&1)^1][j][2][1];\n            }\n            ans1+=1.0*(1<<j)*(f[i&1][j][0][1]-num);\n            ans2+=1.0*(1<<j)*(f[i&1][j][1][1]-num);\n            ans3+=1.0*(1<<j)*(f[i&1][j][2][1]-num);\n        }\n    }\n    ans1/=1.0*n*n,ans2/=1.0*n*n,ans3/=1.0*n*n;\n    printf(\"%.3lf %.3lf %.3lf\",ans1,ans2,ans3);\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 20:34:18"}