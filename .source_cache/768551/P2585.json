{"time": 63, "memory": 16616, "problem": {"pid": "P2585", "title": "[ZJOI2006] 三色二叉树", "difficulty": 4, "type": "P"}, "sourceCodeLength": 1082, "submitTime": 1747313782, "language": 27, "user": {"uid": 768551, "name": "lfh2024", "avatar": "https://cdn.luogu.com.cn/upload/usericon/768551.png", "slogan": "这个家伙很勤快，什么都留下了...", "isAdmin": false, "isBanned": false, "color": "Red", "ccfLevel": 7, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/dqbnruu6.png"}, "id": 217253631, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\nusing namespace std;\nchar s[500010];\nint f[500010][4],g[500010][4];\nint ans=1,cnt;\nvoid dfs(int x)\n{\n    if(s[x]=='0')\n    {\n        f[x][0]=g[x][0]=1;\n        return;\n    }\n    dfs(++cnt);\n    if(s[x]=='1')\n    {\n        f[x][0]=max(f[x+1][1],f[x+1][2])+1;\n        f[x][1]=max(f[x+1][0],f[x+1][2]);\n        f[x][2]=max(f[x+1][0],f[x+1][1]);\n        g[x][0]=min(g[x+1][1],g[x+1][2])+1;\n        g[x][1]=min(g[x+1][0],g[x+1][2]);\n        g[x][2]=min(g[x+1][0],g[x+1][1]);\n    }\n    else\n    {\n        int k=++cnt;\n        dfs(k);\n        f[x][0]=max(f[x+1][1]+f[k][2],f[x+1][2]+f[k][1])+1;\n        f[x][1]=max(f[x+1][0]+f[k][2],f[x+1][2]+f[k][0]);\n        f[x][2]=max(f[x+1][0]+f[k][1],f[x+1][1]+f[k][0]);\n        g[x][0]=min(g[x+1][1]+g[k][2],g[x+1][2]+g[k][1])+1;\n        g[x][1]=min(g[x+1][0]+g[k][2],g[x+1][2]+g[k][0]);\n        g[x][2]=min(g[x+1][0]+g[k][1],g[x+1][1]+g[k][0]);\n    }\n    ans=max(ans,f[x][0]);\n}\nint main()\n{\n    scanf(\"%s\",s+1);\n    int n=strlen(s+1);\n    dfs(++cnt);\n    printf(\"%d %d\",ans,min({g[1][0],g[1][1],g[1][2]}));\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 17:35:06"}