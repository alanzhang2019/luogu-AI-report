{"time": 46, "memory": 620, "problem": {"pid": "P1064", "title": "[NOIP 2006 提高组] 金明的预算方案", "difficulty": 4, "type": "P"}, "sourceCodeLength": 1059, "submitTime": 1751373401, "language": 27, "user": {"uid": 768551, "name": "lfh2024", "avatar": "https://cdn.luogu.com.cn/upload/usericon/768551.png", "slogan": "这个家伙很勤快，什么都留下了...", "isAdmin": false, "isBanned": false, "color": "Red", "ccfLevel": 7, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/dqbnruu6.png"}, "id": 221988727, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 12, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\nusing namespace std;\nint n,m,a[32010][5],f[32010],w[32010],v[32010],p[32010];\nint main()\n{\n    scanf(\"%d%d\",&n,&m);\n    for(int i=1;i<=m;i++)\n    {\n        scanf(\"%d%d%d\",&w[i],&v[i],&p[i]);\n        v[i]*=w[i];\n        if(p[i]!=0)\n        {\n            a[p[i]][++a[p[i]][0]]=i;\n        }\n    }\n    for(int i=1;i<=m;i++)\n    {\n        if(p[i]==0)\n        {\n            for(int j=n;j>=w[i];j--)\n            {\n                f[j]=max(f[j],f[j-w[i]]+v[i]);\n                if(a[i][0]>=1&&j>=w[i]+w[a[i][1]])\n                {\n                    f[j]=max(f[j],f[j-w[i]-w[a[i][1]]]+v[i]+v[a[i][1]]);\n                }\n                if(a[i][0]>=2&&j>=w[i]+w[a[i][2]])\n                {\n                    f[j]=max(f[j],f[j-w[i]-w[a[i][2]]]+v[i]+v[a[i][2]]);\n                }\n                if(a[i][0]>=2&&j>=w[i]+w[a[i][1]]+w[a[i][2]])\n                {\n                    f[j]=max(f[j],f[j-w[i]-w[a[i][1]]-w[a[i][2]]]+v[i]+v[a[i][1]]+v[a[i][2]]);\n                }\n            }\n        }\n    }\n    printf(\"%d\",f[n]);\n    return 0;\n}", "_detail_requested": true, "_cached_at": "2026-06-05 18:25:40"}